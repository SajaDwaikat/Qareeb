{
  "expo": {
    "name": "Qareeb",
    "slug": "Qareeb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "qareeb",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Qareeb to access your photos.",
        "NSCameraUsageDescription": "Allow Qareeb to access your camera."
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Qareeb"
    },

    "web": {
      "output": "static"
    },

    "plugins": [
      "expo-router",

      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Qareeb to access your photos.",
          "cameraPermission": "Allow Qareeb to access your camera."
        }
      ],

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
 //main

      "expo-font",
      "expo-web-browser",
      "expo-sqlite"
 //owner-dashboard-noor
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
